@startuml CareerAI_Part1_Models
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classHeaderBackgroundColor #1E3A5F
skinparam classHeaderFontColor #FFFFFF
skinparam classBorderColor #2C5F8A
skinparam classBackgroundColor #F0F8FF
skinparam arrowColor #2C5F8A
skinparam arrowFontSize 10
skinparam packageBackgroundColor #E8F4F8
skinparam packageBorderColor #2C5F8A
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 50

title CareerAI — Part 1 of 2: Data Models & Relationships\n(See Part 2 for Controllers, Services & Middleware)

' ─────────────────────────────────────────────────────────────
' CORE USER
' ─────────────────────────────────────────────────────────────
package "Core" {
  class User {
    + id : int
    + name : string
    + email : string
    + password : string
    + role : string <<job|company|admin>>
    + phone : string|null
    + business_type : string|null
    + governorate : string
    + fcm_token : string|null
    + avatar_path : string|null
    + email_verified_at : datetime|null
    + created_at : datetime
    + updated_at : datetime
    --
    + jobSeeker() : HasOne
    + company() : HasOne
    + resume() : HasOne
    + sendPasswordResetNotification(token) : void
  }
}

' ─────────────────────────────────────────────────────────────
' PROFILE MODELS
' ─────────────────────────────────────────────────────────────
package "Profiles" {
  class JobSeeker {
    + id : int
    + user_id : int <<FK→users>>
    + phone : string|null
    + created_at : datetime
    + updated_at : datetime
    --
    + user() : BelongsTo
  }

  class Company {
    + id : int
    + user_id : int <<FK→users>>
    + phone : string|null
    + business_type : string|null
    + commercial_register_path : string|null
    + description : string|null
    + verification_status : string <<pending|approved|rejected>>
    + created_at : datetime
    + updated_at : datetime
    --
    + user() : BelongsTo
  }
}

' ─────────────────────────────────────────────────────────────
' JOB & SHORTLIST
' ─────────────────────────────────────────────────────────────
package "Jobs & Hiring" {
  class Job {
    + id : int
    + user_id : int <<FK→users (company)>>
    + title : string
    + job_type : string
    + location : string
    + salary : string
    + description : text
    + requirements : text
    + is_paid : boolean
    + payment_session_id : string|null
    + created_at : datetime
    + updated_at : datetime
    --
    + user() : BelongsTo
  }

  class Shortlist {
    + id : int
    + company_user_id : int <<FK→users.id>>
    + candidate_name : string
    + candidate_email : string
    + candidate_phone : string|null
    + candidate_governorate : string|null
    + candidate_role : string|null
    + match_score : string|null
    + created_at : datetime
    + updated_at : datetime
    --
    + company() : BelongsTo
  }
}

' ─────────────────────────────────────────────────────────────
' AI MODELS
' ─────────────────────────────────────────────────────────────
package "AI & Career" {
  class UserResume {
    + id : int
    + user_id : int <<FK→users>>
    + target_job : string
    + original_text : text
    + current_skills : array <<JSON>>
    + missing_skills : array <<JSON>>
    + created_at : datetime
    + updated_at : datetime
    --
    + user() : BelongsTo
  }

  class UserRoadmap {
    + id : int
    + user_id : int <<FK→users>>
    + target_job : string
    + roadmap_text : text
    + missing_skills : array <<JSON>>
    + suggested_courses : array <<JSON>>
    + completed_skills : array <<JSON>>
    + is_active : boolean
    + created_at : datetime
    + updated_at : datetime
  }

  class UserQuiz {
    + id : int
    + user_id : int <<FK→users>>
    + tested_skills : array <<JSON>>
    + quiz_data : array <<JSON>>
    + score : float|null
    + created_at : datetime
    + updated_at : datetime
  }
}

' ─────────────────────────────────────────────────────────────
' SUPPORT
' ─────────────────────────────────────────────────────────────
package "Support" {
  class Complaint {
    + id : int
    + user_id : int <<FK→users>>
    + role : string
    + subject : string
    + message : text
    + status : string <<pending|in_progress|resolved>>
    + admin_response : string|null
    + resolved_at : datetime|null
    + created_at : datetime
    + updated_at : datetime
    --
    + user() : BelongsTo
  }
}

' ─────────────────────────────────────────────────────────────
' RELATIONSHIPS
' ─────────────────────────────────────────────────────────────
User "1" --down--> "0..1" JobSeeker   : hasOne >
User "1" --down--> "0..1" Company     : hasOne >
User "1" --down--> "0..1" UserResume  : hasOne (resume) >
User "1" --down--> "0..*" Job         : hasMany (posted by company) >
User "1" --down--> "0..*" UserRoadmap : hasMany >
User "1" --down--> "0..*" UserQuiz    : hasMany >
User "1" --down--> "0..*" Complaint   : hasMany >
User "1" --down--> "0..*" Shortlist   : hasMany (as company) >

JobSeeker "1" --up--> "1" User : belongsTo >
Company   "1" --up--> "1" User : belongsTo >
Job       "1" --up--> "1" User : belongsTo (company user) >
UserResume"1" --up--> "1" User : belongsTo >
Complaint "1" --up--> "1" User : belongsTo >
Shortlist "1" --up--> "1" User : belongsTo (company_user_id) >

' ─────────────────────────────────────────────────────────────
' NOTES
' ─────────────────────────────────────────────────────────────
note top of User
  role values:
  "job"     → JobSeeker profile
  "company" → Company profile
  "admin"   → Admin only (no sub-profile)
end note

note bottom of Shortlist
  company_user_id references users.id
  (role='company'). No direct FK to
  Company table. Unique constraint on
  (company_user_id, candidate_email).
  Notification sent only on shortlist action.
end note

note bottom of UserRoadmap
  is_active=true → current roadmap.
  completed_skills updated after
  passing quiz (score >= 70%).
end note

note right of UserResume
  Populated by AiController::analyzeGap().
  Used by JobController for AI candidate
  matching & shortlisting.
end note

@enduml
